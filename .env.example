# Google OAuth (Google Cloud Console -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
ALLOWED_DOMAIN=muze.co.th

# Session signing secret - generate with: openssl rand -hex 32
SESSION_SECRET=

# nissan-report-tool (Fly.io) - same Basic Auth credentials already set as Fly secrets
REPORT_TOOL_BASE_URL=https://nissan-report-tool.fly.dev
REPORT_TOOL_BASIC_AUTH_USER=
REPORT_TOOL_BASIC_AUTH_PASSWORD=

# muze-jira-dashboard (Vercel) - same DASHBOARD_SECRET already set as a Vercel secret
DASHBOARD_BASE_URL=https://muze-jira-dashboard.vercel.app
DASHBOARD_SECRET=

PORT=3000
